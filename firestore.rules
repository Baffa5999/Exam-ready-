rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Catch-all Safeguard (Design Pattern: Fortress Gate)
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable Security Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Validation Blueprint
    function isValidUser(data) {
      return data.uid is string 
        && data.uid == request.auth.uid 
        && data.email is string 
        && data.email.size() <= 200
        && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
        && (data.examType == null || data.examType in ['JAMB', 'WAEC', 'NECO'])
        && (data.targetScore == null || data.targetScore is int)
        && (data.streak == null || data.streak is int)
        && (data.questionsPracticed == null || data.questionsPracticed is int)
        && (data.accuracy == null || data.accuracy is int);
    }

    // Firestore Collection Rules for users
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      
      allow create: if isOwner(userId) 
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isOwner(userId)
        && isValidId(userId)
        && isValidUser(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
        
      allow delete: if isOwner(userId) && isValidId(userId);
    }
  }
}
